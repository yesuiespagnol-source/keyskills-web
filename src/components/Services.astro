---
const services = [
  {
    title: 'Consultoría Estratégica',
    description: 'Definimos la hoja de ruta para tu crecimiento. Análisis competitivo, planificación a largo plazo y ejecución impecable.',
    icon: 'strategy',
    features: ['Análisis de mercado', 'Planificación estratégica', 'OKRs y KPIs', 'Gestión del cambio']
  },
  {
    title: 'Optimización de Procesos',
    description: 'Streamlinemnos operaciones y eliminamos ineficiencias. Implementamos metodologías probadas que multiplican tu productividad.',
    icon: 'process',
    features: ['Mapeo de procesos', 'Gestión lean', 'Automatización', 'Control de calidad']
  },
  {
    title: 'Marketing Estratégico',
    description: 'Atraer, convertir y fidelizar. Diseñamos estrategias de marketing que generan resultados medibles y sostenibles.',
    icon: 'marketing',
    features: ['Estrategia digital', 'Contenido de valor', 'Marketing de crecimiento', 'Posicionamiento de marca']
  },
  {
    title: 'RRHH y Talento',
    description: 'Construimos equipos de alto rendimiento. Selección, desarrollo del talento y cultura organizacional que retiene.',
    icon: 'people',
    features: ['Marca empleadora', 'Desarrollo de liderazgo', 'Gestión del talento', 'Evaluación del desempeño']
  }
];
---

<section class="services section" id="servicios">
  <div class="container">
    <div class="section-header text-center">
      <span class="section-label reveal">Áreas de Especialización</span>
      <h2 class="section-title reveal">Soluciones Integrales para tu Empresa</h2>
      <p class="section-subtitle reveal">
        Cada área de negocio requiere un enfoque único. Combinamos experiencia sectorial
        con metodologías probadas para lograr resultados excepcionales.
      </p>
    </div>

    <div class="services-grid" data-stagger>
      {services.map((service, index) => (
        <div class="service-card reveal" style={`transition-delay: ${index * 0.1}s`}>
          <div class="service-header">
            <div class="service-icon">
              {service.icon === 'strategy' && (
                <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
                  <circle cx="24" cy="24" r="20"/>
                  <path d="M24 4v8M24 36v8M4 24h8M36 24h8"/>
                  <circle cx="24" cy="24" r="8"/>
                </svg>
              )}
              {service.icon === 'process' && (
                <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
                  <rect x="6" y="6" width="36" height="36" rx="4"/>
                  <path d="M6 18h36M6 30h36M18 6v36M30 6v36"/>
                </svg>
              )}
              {service.icon === 'marketing' && (
                <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M42 24c0 9.94-8.06 18-18 18S6 33.94 6 24 14.06 6 24 6s18 8.06 18 18z"/>
                  <path d="M24 14v20M14 24h20"/>
                  <circle cx="24" cy="24" r="4"/>
                </svg>
              )}
              {service.icon === 'people' && (
                <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.5">
                  <circle cx="16" cy="14" r="6"/>
                  <circle cx="32" cy="14" r="6"/>
                  <path d="M6 42c0-6 5.37-10 10-10h16c4.63 0 10 4 10 10"/>
                  <path d="M26 26c3 2 6 3 10 3M12 26c-3 2-6 3-10 3"/>
                </svg>
              )}
            </div>
            <h3 class="service-title">{service.title}</h3>
          </div>

          <p class="service-description">{service.description}</p>

          <div class="service-features">
            {service.features.map((feature) => (
              <span class="feature-tag">{feature}</span>
            ))}
          </div>

          <a href="#contacto" class="service-link">
            Explorar más
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services {
    background: var(--color-white);
  }

  .section-header {
    margin-bottom: 4rem;
  }

  .section-header .section-label,
  .section-header .section-title,
  .section-header .section-subtitle {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .section-header.visible .section-label,
  .section-header.visible .section-title,
  .section-header.visible .section-subtitle {
    opacity: 1;
    transform: translateY(0);
  }

  .section-header .section-label { transition-delay: 0s; }
  .section-header .section-title { transition-delay: 0.1s; }
  .section-header .section-subtitle { transition-delay: 0.2s; }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .service-card {
    background: var(--color-white);
    border: 1px solid rgba(10, 22, 40, 0.08);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    position: relative;
    overflow: hidden;
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .service-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .service-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--color-accent), var(--color-accent-light));
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .service-card:hover::before {
    transform: scaleX(1);
  }

  .service-card:hover {
    border-color: transparent;
    box-shadow: var(--shadow-lg);
    transform: translateY(-8px);
  }

  .service-header {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    margin-bottom: 1.5rem;
  }

  .service-icon {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(201, 162, 39, 0.1), rgba(201, 162, 39, 0.05));
    border-radius: var(--radius-md);
    color: var(--color-accent);
    transition: all 0.3s ease;
  }

  .service-icon svg {
    width: 32px;
    height: 32px;
  }

  .service-card:hover .service-icon {
    background: var(--color-accent);
    color: var(--color-white);
    transform: scale(1.05);
  }

  .service-title {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--color-primary);
    line-height: 1.3;
    padding-top: 0.5rem;
  }

  .service-description {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
  }

  .service-features {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .feature-tag {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--color-secondary);
    background: rgba(30, 58, 95, 0.08);
    padding: 0.35rem 0.75rem;
    border-radius: 100px;
    transition: all 0.3s ease;
  }

  .service-card:hover .feature-tag {
    background: rgba(201, 162, 39, 0.1);
    color: var(--color-accent);
  }

  .service-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    transition: all 0.3s ease;
  }

  .service-link svg {
    width: 18px;
    height: 18px;
    transition: transform 0.3s ease;
  }

  .service-link:hover {
    color: var(--color-primary);
  }

  .service-link:hover svg {
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }

    .service-card {
      padding: 2rem;
    }
  }
</style>
