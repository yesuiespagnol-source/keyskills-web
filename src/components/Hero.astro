---
import heroBg from '../assets/hero-bg.jpg'
---

<section class="hero" id="inicio">
  <div class="hero-bg">
    <img
      src={heroBg.src}
      alt="Modern corporate building"
      class="hero-image"
    />
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-content">
    <div class="hero-text">
      <span class="hero-label animate-fade-up">Consultoría Estratégica de Alto Impacto</span>
      <h1 class="hero-title">
        <span class="hero-line animate-fade-up delay-1">Transformamos</span>
        <span class="hero-line animate-fade-up delay-2">Complejidad en</span>
        <span class="hero-line hero-accent animate-fade-up delay-3">Resultados</span>
      </h1>
      <p class="hero-subtitle animate-fade-up delay-4">
        Más de 30 años de experiencia impulsando empresas hacia la excelencia operativa,
        el crecimiento sostenible y la transformación organizacional.
      </p>
      <div class="hero-cta animate-fade-up delay-5">
        <a href="#contacto" class="btn btn-primary">
          Agenda una Consulta
        </a>
        <a href="#servicios" class="btn btn-outline">
          Nuestros Servicios
        </a>
      </div>
    </div>

    <div class="hero-scroll">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </div>

  <div class="hero-stats">
    <div class="container">
      <div class="stats-row">
        <div class="stat-item">
          <span class="stat-number">+30</span>
          <span class="stat-label">Años de Experiencia</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-number">+150</span>
          <span class="stat-label">Proyectos Exitosos</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-number">98%</span>
          <span class="stat-label">Clientes Satisfechos</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: transparent;
  }

  .hero-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: 120px;
    padding-bottom: 160px;
    position: relative;
  }

  .hero-text {
    max-width: 800px;
  }

  .hero-label {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.5rem;
    opacity: 0;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 5.5rem);
    font-weight: 700;
    line-height: 1.05;
    color: var(--color-white);
    margin-bottom: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.1em;
  }

  .hero-line {
    opacity: 0;
  }

  .hero-accent {
    background: linear-gradient(90deg, var(--color-accent) 0%, var(--color-accent-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.25rem);
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.8);
    max-width: 600px;
    margin-bottom: 2.5rem;
    opacity: 0;
  }

  .hero-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    opacity: 0;
  }

  .hero-cta .btn {
    padding: 1rem 2rem;
    font-size: 0.85rem;
  }

  .hero-cta .btn-outline {
    border-color: rgba(255, 255, 255, 0.4);
  }

  .hero-cta .btn-outline:hover {
    border-color: var(--color-white);
    background: rgba(255, 255, 255, 0.1);
  }

  .hero-scroll {
    position: absolute;
    right: 0;
    bottom: 180px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, var(--color-accent), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }

  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(1); }
    50% { opacity: 1; transform: scaleY(1.2); }
  }

  .hero-stats {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(28, 36, 33, 0.8);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 2rem 0;
  }

  .stats-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .stat-item {
    text-align: center;
  }

  .stat-number {
    display: block;
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.7);
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: rgba(255, 255, 255, 0.2);
  }

  @media (max-width: 768px) {
    .hero-content {
      padding-bottom: 220px;
    }

    .hero-scroll {
      display: none;
    }

    .hero-stats {
      padding: 1.5rem 0;
    }

    .stats-row {
      gap: 1.5rem;
    }

    .stat-number {
      font-size: 2rem;
    }

    .stat-divider {
      display: none;
    }

    .hero-cta {
      flex-direction: column;
    }

    .hero-cta .btn {
      width: 100%;
    }
  }
</style>
