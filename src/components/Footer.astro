---
import LogoKeyskills from '../assets/keyskills-logo-white.png';
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="#inicio" class="footer-logo">
          <img src={LogoKeyskills.src} alt="Keyskills" class="footer-logo-img" />
        </a>
        <p class="footer-tagline">
          Consultoría estratégica para empresas que buscan la excelencia.
        </p>
      </div>

      <div class="footer-links">
        <h4>Navegación</h4>
        <ul>
          <li><a href="#inicio">Inicio</a></li>
          <li><a href="#servicios">Servicios</a></li>
          <li><a href="#metodo">Metodología</a></li>
          <li><a href="#nosotros">Nosotros</a></li>
          <li><a href="#contacto">Contacto</a></li>
        </ul>
      </div>

      <div class="footer-links">
        <h4>Servicios</h4>
        <ul>
          <li><a href="#servicios">Consultoría Estratégica</a></li>
          <li><a href="#servicios">Optimización de Procesos</a></li>
          <li><a href="#servicios">Marketing Estratégico</a></li>
          <li><a href="#servicios">People & HR</a></li>
        </ul>
      </div>

      <div class="footer-contact">
        <h4>Contacto</h4>
        <div class="footer-contact-items">
          <a href="tel:+34663906932" class="footer-contact-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 5a2 2 0 0 1 2-2h3.28a1 1 0 0 1 .948.684l1.498 4.493a1 1 0 0 1-.502 1.21l-2.257 1.13a11.042 11.042 0 0 0 5.516 5.516l1.13-2.257a1 1 0 0 1 1.21-.502l4.493 1.498a1 1 0 0 1 .684.949V19a2 2 0 0 1-2 2h-1C9.716 21 3 14.284 3 6V5z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>+34 663 906 932</span>
          </a>
          <a href="mailto:hello@keyskills.es" class="footer-contact-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M3 8l7.89 5.26a2 2 0 0 0 2.22 0L21 8M5 19h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2z" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>hello@keyskills.es</span>
          </a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; 2026 Keyskills Consulting. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-primary);
    padding: var(--space-xl) 0 var(--space-md);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: 3rem;
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-brand {
    max-width: 280px;
  }

  .footer-logo {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-white);
  }

  .footer-logo-img {
    height: 40px;
    width: auto;
  }

  .logo-accent {
    color: var(--color-accent);
  }

  .footer-tagline {
    margin-top: 1rem;
    font-size: 0.9rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.6);
  }

  .footer-links h4,
  .footer-contact h4 {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 1.25rem;
  }

  .footer-links ul {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-links a {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
    transition: all 0.3s ease;
  }

  .footer-links a:hover {
    color: var(--color-white);
    padding-left: 4px;
  }

  .footer-contact-items {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-contact-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
    transition: all 0.3s ease;
  }

  .footer-contact-item svg {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    color: var(--color-accent);
  }

  .footer-contact-item:hover {
    color: var(--color-white);
  }

  .footer-bottom {
    padding-top: var(--space-md);
    text-align: center;
  }

  .footer-bottom p {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.5);
    margin: 0;
  }

  @media (max-width: 900px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer-brand {
      grid-column: 1 / -1;
      max-width: none;
      text-align: center;
    }
  }

  @media (max-width: 600px) {
    .footer-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .footer-links a:hover {
      padding-left: 0;
    }

    .footer-contact-item {
      justify-content: center;
    }
  }
</style>
